# Copy to .env and fill in. All values are PUBLIC (client-side) — no secrets here.
# Analytics is optional: with no key set, events log to the console in dev and are
# silent in prod. Never call posthog.identify() — kid-safe anonymous events only.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
